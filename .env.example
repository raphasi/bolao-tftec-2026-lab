# ===== Cosmos DB =====
COSMOS_ENDPOINT=https://fifa2026-bolao-cosmos.documents.azure.com:443/
COSMOS_KEY=<primary-key-from-portal>
COSMOS_DATABASE=bolao2026

# ===== Backend =====
PORT=3001
NODE_ENV=development
JWT_SECRET=<gere-com-openssl-rand-base64-32>
JWT_EXPIRES_IN=7d

# ===== Main app integration (OPCIONAL) =====
# Integração com uma API externa de jogos. Deixe em branco no self-host — o app funciona sem.
# MAIN_API_BASE_URL=https://<seu-main-app>.azurewebsites.net/api

# ===== SignalR =====
SIGNALR_CONNECTION_STRING=Endpoint=https://fifa2026-bolao-signalr.service.signalr.net;AccessKey=...

# ===== Application Insights =====
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ===== Frontend (build-time) =====
VITE_API_BASE_URL=http://localhost:3001/api
VITE_SIGNALR_HUB_URL=http://localhost:3001/hub
