# ===== Runtime =====
NODE_ENV=development
PORT=3001

# ===== Cosmos DB =====
# Capturar com:
#   az cosmosdb show --name <conta> --resource-group <seu-rg> --query documentEndpoint -o tsv
#   az cosmosdb keys list --name <conta> --resource-group <seu-rg> --query primaryMasterKey -o tsv
COSMOS_ENDPOINT=https://cosmos-fifa-bolao-XXXX.documents.azure.com:443/
COSMOS_KEY=<primary-key>
COSMOS_DATABASE=bolao2026

# ===== Auth (JWT) =====
# Gerar com: openssl rand -base64 32
JWT_SECRET=<min-32-chars>
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ===== Integração com main app (OPCIONAL) =====
# Deixe em branco no self-host — o app funciona sem.
# MAIN_API_BASE_URL=https://<seu-main-app>.azurewebsites.net/api

# ===== SignalR (opcional em dev) =====
SIGNALR_CONNECTION_STRING=

# ===== Application Insights (opcional em dev) =====
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ===== CORS =====
# Em dev: * (permite tudo). Em prod: separar por vírgula.
CORS_ORIGINS=*

# ===== Rate limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
